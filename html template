<div class="container">

  <h1>Item List</h1>

  <div *ngIf="loading">
    Loading items...
  </div>

  <div *ngIf="errorMessage" class="error">
    {{ errorMessage }}
  </div>

  <div *ngIf="!loading && !errorMessage">

    <div class="card" *ngFor="let item of items">

      <h2>{{ item.name }}</h2>

      <p><strong>ID:</strong> {{ item.id }}</p>

      <p>{{ item.description }}</p>

    </div>

  </div>

</div>
