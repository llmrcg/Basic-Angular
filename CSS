.container {
    width: 80%;
    margin: 40px auto;
    font-family: Arial, Helvetica, sans-serif;
}

h1 {
    text-align: center;
    margin-bottom: 30px;
}

.card {
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 15px;
    box-shadow: 0 2px 5px rgba(0,0,0,.1);
}

.card h2 {
    color: #1976d2;
    margin-bottom: 10px;
}

.error {
    color: red;
    font-weight: bold;
    text-align: center;
}
